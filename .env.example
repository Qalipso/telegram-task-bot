# AI Work Intelligence Platform — environment template.
# Copy to .env and fill real values. NEVER commit .env (see .gitignore).

# --- Runtime ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Postgres (consumed by the postgres container) ---
POSTGRES_USER=aiwip
POSTGRES_PASSWORD=aiwip
POSTGRES_DB=aiwip

# --- Service connection strings ---
# Inside docker-compose use host "postgres"/"redis"; for host-side runs use localhost.
DATABASE_URL=postgresql+psycopg://aiwip:aiwip@postgres:5432/aiwip
REDIS_URL=redis://redis:6379/0

# --- Worker ---
WORKER_HEARTBEAT_SECONDS=30

# --- Auth (Stage 3) ---
SECRET_KEY=dev-insecure-change-me

# --- Telegram (Stage 4 — Telethon user session) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION=

# --- Bot service (bot-first capture layer, Phase 2+) — Telegram Bot API ---
# Bot token from BotFather. Privacy mode OFF + bot must be a group admin (design spec §6.3).
# Leave BLANK for token-less / CI-safe boot (no long-poll).
TELEGRAM_BOT_TOKEN=
# Where the bot reaches the platform API. In docker-compose this is the api hostname.
BOT_API_BASE=http://api:8000
# Bot-service admin login (the bot logs in once and replays the aiwip_session cookie).
# Treat as a top-tier secret: this is full admin API access (spec §13).
BOT_ADMIN_EMAIL=
BOT_ADMIN_PASSWORD=
# Where confirm cards + digests are sent: the admin's Telegram chat id (DM) or a private review
# group the bot is in. REQUIRED when TELEGRAM_BOT_TOKEN is set. Get yours from @userinfobot.
BOT_REVIEW_CHAT_ID=
BOT_GETUPDATES_TIMEOUT=30
# Loop cadences (seconds).
BOT_POLL_INTERVAL_SECONDS=30
BOT_DEBOUNCE_SECONDS=60
BOT_DIGEST_INTERVAL_SECONDS=300
# Confidence bands (spec §6.2).
AUTO_BAND=0.90
REVIEW_BAND=0.60
# Quiet hours (UTC, per decision D4). Default ON.
QUIET_HOURS_ENABLED=true
QUIET_HOURS_START_UTC=22
QUIET_HOURS_END_UTC=8
# NOTE: docker-compose runs a BUILT image — after editing bot/src/... rebuild:
#   docker compose build bot && docker compose up -d bot

# --- OpenAI (Stage 8) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Error tracking (optional) — set the DSN from your Sentry project to enable
SENTRY_DSN=
