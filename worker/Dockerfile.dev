# Development Dockerfile for Worker with hot-reload
FROM python:3.12-alpine

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PATH=/app/.local/bin:$PATH

RUN apk add --no-cache gcc musl-dev libffi-dev openssl-dev python3-dev

RUN addgroup -g 1000 appuser && adduser -D -u 1000 -G appuser appuser

WORKDIR /app

# Install core and worker in editable mode for development
COPY core ./core
RUN pip install --user --no-cache-dir -e ./core

COPY worker ./worker
RUN pip install --user --no-cache-dir -e ./worker

USER appuser

# Install watchfiles for auto-restart
RUN pip install --user watchfiles

CMD ["watchfiles", "python", "-m", "aiwip_worker.main"]
